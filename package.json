{
  "name": "@ofux/lauren",
  "version": "0.1.1",
  "description": "Queue-driven plan/vibe lifecycle runner",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "lauren": "dist/bin/lauren.js"
  },
  "files": [
    "dist",
    "!dist/bin/vibe.js",
    "!dist/bin/vibe.js.map"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ofux/lauren.git"
  },
  "homepage": "https://github.com/ofux/lauren#readme",
  "bugs": {
    "url": "https://github.com/ofux/lauren/issues"
  },
  "keywords": [
    "claude",
    "codex",
    "agent",
    "automation",
    "cli",
    "queue",
    "ralph"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/bin/lauren.js",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "check": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
